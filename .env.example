# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Mock Switch ──────────────────────────────────────────────────────────────
# Set to true to use mock APIs (no real credentials needed)
# Set to false to use real APIs (all keys below must be filled in)
USE_MOCK_API=true

# ─── Follow Up Boss ───────────────────────────────────────────────────────────
# Auth: HTTP Basic (API key as username, empty password)
# Header: x-system-key required alongside Basic Auth
FUB_API_KEY=
FUB_SYSTEM_KEY=

# ─── BambooHR ─────────────────────────────────────────────────────────────────
# Auth: HTTP Basic (API key as username, 'x' as password)
BAMBOOHR_API_KEY=
BAMBOOHR_SUBDOMAIN=

# ─── Deel ─────────────────────────────────────────────────────────────────────
# Auth: Bearer token
DEEL_API_KEY=

# ─── Jira Service Management ──────────────────────────────────────────────────
# Auth: Bearer token
JIRA_API_TOKEN=
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_PROJECT_KEY=OB
JIRA_EMAIL=

# ─── Webhook Security ─────────────────────────────────────────────────────────
# Shared secrets for validating inbound webhook payloads
FUB_WEBHOOK_SECRET=
BAMBOOHR_WEBHOOK_SECRET=
DEEL_WEBHOOK_SECRET=
